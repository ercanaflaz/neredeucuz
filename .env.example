# .env olarak kopyala. ASLA repoya commitleme (.gitignore'da olmalı).
# Aynı değişkenleri Cloudflare Pages → Settings → Environment variables'a da ekle.
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_KEY=sb_publishable_xxxxx

# Google AdSense (yayına almadan önce doldur; boşsa reklam yeri yer tutucu görünür)
VITE_ADSENSE_CLIENT=
VITE_ADSENSE_SLOT_LIST=
VITE_ADSENSE_SLOT_PRODUCT=

# Barkod tanıma (barkodoku.com) — barkod marketfiyati'de yoksa ürün adını bulur.
# VITE değil; Cloudflare Pages → Settings → Environment variables'a da ekle:
#   BARKODOKU_USER_KEY=...
#   BARKODOKU_API_KEY=...
# Yoksa barkod tanıma Open Food Facts'e düşer.

# Akıllı Sepet doğal dil ayrıştırma için (OPSİYONEL) — Google AI Studio ücretsiz anahtar.
# VITE değişkeni DEĞİL; Cloudflare Pages → Settings → Environment variables'a eklenir:
#   GEMINI_API_KEY=...              (functions/api/gemini.js sunucu tarafında kullanır)
#   GEMINI_MODEL=gemini-2.0-flash  (opsiyonel)
# Anahtar yoksa Akıllı Sepet yine çalışır (basit ayrıştırıcıya düşer).
